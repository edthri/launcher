{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "console",
  "description": "Capability for native console windows (label console-*)",
  "windows": [
    "console-*"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "clipboard-manager:allow-write-text",
    "core:webview:allow-set-webview-zoom"
  ]
}
